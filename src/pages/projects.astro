---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="Demo Project 1"
    img="/post_img.webp"
    desc="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    url="#"
    badge="NEW"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Demo Project 2"
    img="/post_img.webp"
    desc="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    url="#"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Explorations</div>
  </div>

  <HorizontalCard
    title="KMeans Clustering with Visualization"
    img="/post_img.webp"
    desc="KMeans clustering algorithm with visualization. Includes demo video."
    url="https://github.com/michaelliruoxi/mlrx-assignment-2"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Search Engine"
    img="/post_img.webp"
    desc="Search engine project with demo video."
    url="https://github.com/michaelliruoxi/mlrx-assignment-4"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Kaggle: Predicting Customer Churn Using KNN"
    img="/post_img.webp"
    desc="Kaggle competition — predicting customer churn using KNN."
    url="https://github.com/michaelliruoxi/mlrx-assignment-5"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Kaggle: Amazon Movie Review Star Rating"
    img="/post_img.webp"
    desc="Kaggle competition — predicting star rating for Amazon movie reviews."
    url="https://github.com/michaelliruoxi/mlrx-cs506-midterm"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Linear Regression Experiments"
    img="/post_img.webp"
    desc="Linear regression experiments with demo video."
    url="https://github.com/michaelliruoxi/mlrx-assignment-6"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Hypothesis Testing and Confidence Intervals in Linear Regression"
    img="/post_img.webp"
    desc="Hypothesis testing and confidence intervals in linear regression. Includes demo video."
    url="https://github.com/michaelliruoxi/mlrx-assignment-7"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Logistic Regression Cluster Shift Experiment"
    img="/post_img.webp"
    desc="Logistic regression cluster shift experiment with demo video."
    url="https://github.com/michaelliruoxi/mlrx-assignment-8"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Visualizing Neural Networks"
    img="/post_img.webp"
    desc="Visualizing neural networks with demo video."
    url="https://github.com/michaelliruoxi/mlrx-assignment-9"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Identifying Credit Card Fraud"
    img="/post_img.webp"
    desc="Identifying credit card fraud using machine learning."
    url="https://github.com/michaelliruoxi/mlrx-cs506-extracredit"
  />
</BaseLayout>
