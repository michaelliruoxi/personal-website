---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

const blogPosts = await getCollection("blog");
blogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPost = blogPosts[0];
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Michael Li</div>
    <div class="text-3xl py-3 font-bold">Student @ Columbia University</div>
    <div class="py-2">
      <text class="text-lg">
        I am a quantitative graduate student at Columbia University pursuing an M.A. in Quantitative Methods in the Social Sciences, with a strong foundation in economics, and computer science from Boston University. I focus on applying data-driven analysis to understand market trends and investment opportunities.
        
        I thrive at the intersection of data and decision-making, with experience in investment banking and fixed income research through internships at CICC and Haitong Securities. My work has included IPO valuation, financial due diligence, and bond risk assessment using Bloomberg, Wind, and Capital IQ.
        
        With strong training in machine learning and econometrics, I bring a quantitative mindset to financial analysis. Currently seeking 2026 internship opportunities in financial analytics.
      </text>
    </div>

    <!--
    <div class="mt-8">
      <a class="btn" href="www.linkedin.com/in/michael-li-03abc" target="_blank"> Let's connect!</a>
      <a href="https://github.com/michaelliruoxi" target="_blank" class="btn btn-outline ml-5">
        GitHub
      </a>
    </div>
    -->
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">My last projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="COVID-19 Chest X-Ray Classification with Deep Learning"
    img="/chest_xray.jpg"
    desc="Built and compared six CNN architectures (custom and transfer learning) to classify chest X-rays as COVID-19, Normal, or Viral Pneumonia — achieving 95.7% accuracy and 0.99 AUC."
    url="https://github.com/michaelliruoxi/medical_deeplearning"
    badge="Deep Learning"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Natural Language Processing for Student Rating Prediction"
    img="/nlp_cover.png"
    desc="How do students really think about their professors? I used NLP on 20k+ RateMyProfessor reviews to predict star ratings from the text — and got accuracy up to ~69%."
    url="https://github.com/michaelliruoxi/prof_rating_nlp"
    badge="NLP"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Wave Height Prediction — Surf Vacation Planner"
    img="/remagic_cover.jpeg"
    desc="A time-series forecasting app that predicts ocean wave heights using Facebook Prophet and NOAA buoy data, helping surfers find optimal locations and dates for their next trip."
    url="/cs506-wave-prediction"
    target="_self"
    badge="Time Series"
  />

  {
    latestPost && (
      <>
        <div class="mt-14 mb-3">
          <div class="text-3xl w-full font-bold mb-2">Blog / Journal</div>
          <p class="text-base-content/80 max-w-3xl">
            Here are my most recent blogs.
          </p>
        </div>
        <HorizontalCard
          title={latestPost.data.title}
          desc={latestPost.data.description}
          url={`/blog/${createSlug(latestPost.data.title, latestPost.slug, latestPost.data.slug)}`}
          target="_self"
          badge="Latest entry"
          tags={latestPost.data.tags}
        />
        <div class="mt-4">
          <a class="btn btn-outline" href="/blog">Read the journal</a>
        </div>
      </>
    )
  }

</BaseLayout>
