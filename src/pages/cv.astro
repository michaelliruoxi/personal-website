---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    I am a Columbia University M.A. student in Quantitative Methods in the Social Sciences (QMSS) with a Computer Science and
    Economics background from Boston University. I enjoy working at the intersection of data science and finance, with
    experience in investment banking and fixed income research, and hands-on projects in NLP and applied econometrics.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Columbia University — M.A. in Quantitative Methods in the Social Sciences"
      subtitle="Sep 2025 to Feb 2027 • New York, NY • GPA: 4.00/4.00 • Coursework: Advanced Machine Learning, Data Visualization, Advanced Deep Learning, Business Analytics"
    />
    <TimeLineElement
      title="Boston University — B.A. in Computer Science and Economics"
      subtitle="Jan 2022 to May 2025 • Boston, MA • Advanced Coursework GPA: 3.71 • Dean’s List (Fall 2023, Spring 2024, Fall 2024) • Coursework: Analysis of Algorithms, Empirical Econometrics, Databases, Geometric Algorithms"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Investment Banking Summer Analyst — China International Capital Corporation (CICC)"
      subtitle="May 2024 to Jun 2024 • Beijing, China"
    >
      <ul class="list-disc mx-6 grid gap-2">
        <li>
          Screened valuation multiples and market data (Bloomberg, Wind, Capital IQ, FactSet) and helped develop a 104-page
          IPO pitch for a leading cloud computing platform with industry benchmarking and competitive positioning analysis.
        </li>
        <li>
          Verified financial figures and corrected discrepancies in an English prospectus (300+ pages) by cross-checking
          updated statements and recalculating growth rates, income metrics, and cash-flow items.
        </li>
        <li>
          Built two financial due diligence questionnaires for a children’s digital reading platform by identifying
          reconciliation gaps and drafting metric-specific follow-ups on operations, management, and capital structure.
        </li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Fixed Income Summer Analyst — Haitong Securities (Bond Financing Department)"
      subtitle="Jul 2023 to Aug 2023 • Beijing, China"
    >
      <ul class="list-disc mx-6 grid gap-2">
        <li>
          Supported five bond issuance initiation reports by evaluating issuance structures, issuer qualifications, funding
          purposes, and preliminary risk factors; conducted compliance and regulatory analysis for two large financial
          institutions.
        </li>
        <li>
          Evaluated bond issuance feasibility for five target companies by reviewing offering documents, disclosures,
          governance/ownership structures, related-party transactions, litigation/regulatory records, and credit rating reports.
        </li>
        <li>
          Produced 80+ pages of due diligence working papers and pre-issuance reports to support compliance reviews and
          multi-layer risk-control procedures; synthesized industry, credit, and ESG research into investor-facing risk profiles.
        </li>
      </ul>
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Projects & Leadership</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Natural Language Processing for Student Rating Prediction — Research Team Leader"
      subtitle="Sep 2025 to Dec 2025 • New York, NY"
    >
      <ul class="list-disc mx-6 grid gap-2">
        <li>
          Built models over 20,000+ RateMyProfessor reviews to predict student star ratings from written course feedback,
          demonstrating how unstructured text can be converted into quantitative insights.
        </li>
        <li>
          Developed an end-to-end pipeline: cleaned and standardized ratings into 9 levels (1.0–5.0), transformed text into
          numerical features using TF-IDF, and expanded training data from 15,992 to 35,230 via controlled text augmentation.
        </li>
        <li>
          Benchmarked six models and evaluated performance with accuracy and class-level metrics, improving exact rating
          prediction from 43.1% to 69.4% in the best-performing model.
        </li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Wages and Working Hours Econometrics Research Project — Research Team Leader"
      subtitle="Sep 2023 to Dec 2023 • Boston, MA"
    >
      <ul class="list-disc mx-6 grid gap-2">
        <li>
          Analyzed 200,000+ observations from the 2009, 2019, and 2021 Current Population Survey cross-sectional datasets to
          study the relationship between wages and weekly working hours.
        </li>
        <li>
          Built econometric regression models in Stata, ran hypothesis tests, and interpreted functional forms and controls;
          co-authored a 28-page study finding hours respond weakly to wage growth but strongly to education, gender, and family status.
        </li>
      </ul>
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <div class="mb-2 font-semibold">Technical</div>
  <ul class="list-disc md:columns-4 columns-2 mx-6 mb-8">
    <li>Python</li>
    <li>Machine Learning</li>
    <li>SQL</li>
    <li>R</li>
    <li>Stata</li>
    <li>Java</li>
    <li>C</li>
    <li>Excel</li>
    <li>Bloomberg</li>
    <li>Wind</li>
    <li>Capital IQ</li>
    <li>FactSet</li>
  </ul>

  <div class="mb-2 font-semibold">Languages</div>
  <ul class="list-disc md:columns-3 columns-2 mx-6 mb-8">
    <li>English (Fluent)</li>
    <li>Mandarin Chinese (Fluent)</li>
  </ul>

  <div class="mb-2 font-semibold">Interests</div>
  <ul class="list-disc md:columns-3 columns-2 mx-6">
    <li>Classical Music (Violin)</li>
    <li>Skiing</li>
    <li>Soccer</li>
    <li>Columbia CS2 Esports Team</li>
    <li>Formula 1</li>
  </ul>
</BaseLayout>
